{
  "enabled": true,
  "name": "Auto Git Commit",
  "description": "Commit automatique de tous les fichiers modifiés après chaque session agent",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "sleep 2 && git add -A && git diff --cached --quiet || git commit -m \"chore: auto-commit modifications Kiro\""
  }
}